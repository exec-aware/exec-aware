ldso: add exec-awareness to dlopen

From: Skye Soss <skye@soss.website>

Before a shared library is loaded, first check that the file is marked as
executable. If not, and enforcement is enabled, the call to dlopen will fail.
---
 ldso/dynlink.c |   17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/ldso/dynlink.c b/ldso/dynlink.c
index 715948f..9fe2b17 100644
--- a/ldso/dynlink.c
+++ b/ldso/dynlink.c
@@ -19,11 +19,17 @@
 #include <dlfcn.h>
 #include <semaphore.h>
 #include <sys/membarrier.h>
+#include <sys/prctl.h>
 #include "pthread_impl.h"
 #include "fork_impl.h"
 #include "libc.h"
 #include "dynlink.h"
 
+/* <linux/fcntl.h> */
+#define AT_EXECVE_CHECK 0x10000
+/* <linux/securebits.h> */
+#define SECBIT_EXEC_RESTRICT_FILE (1 << 8)
+
 static size_t ldso_page_size;
 /* libc.h may have defined a macro for dynamic PAGE_SIZE already, but
  * PAGESIZE is only defined if it's constant for the arch. */
@@ -1167,6 +1173,17 @@ static struct dso *load_library(const char *name, struct dso *needed_by)
 		close(fd);
 		return 0;
 	}
+	/* The shared library should be marked as executable.
+	 * A non-executable file is not an error unless the
+	 * EXEC_RESTRICT_FILE securebit is set.
+	 */
+	if (syscall(SYS_execveat, fd, "", NULL, NULL, AT_EMPTY_PATH | AT_EXECVE_CHECK) < 0) {
+		int secbits = prctl(PR_GET_SECUREBITS);
+		if (secbits >= 0 && (secbits & SECBIT_EXEC_RESTRICT_FILE)) {
+			close(fd);
+			return 0;
+		}
+	}
 	for (p=head->next; p; p=p->next) {
 		if (p->dev == st.st_dev && p->ino == st.st_ino) {
