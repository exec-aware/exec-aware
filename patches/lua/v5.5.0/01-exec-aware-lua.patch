+    if (checkexec && check_fd_exec(0) < 0 && exec_deny_interactive()) {
+      errno = EACCES;
+      return errfile(L, "execute", fnameindex);
+    }
   }
   else {
     lua_pushfstring(L, "@%s", filename);
     errno = 0;
