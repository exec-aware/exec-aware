diff --git a/src/lauxlib.c b/src/lauxlib.c
index 7cf90cb..192bc95 100644
--- a/src/lauxlib.c
+++ b/src/lauxlib.c
@@ -814,12 +814,21 @@ LUALIB_API int luaL_loadfilex (lua_State *L, const char *filename,
   if (filename == NULL) {
     lua_pushliteral(L, "=stdin");
     lf.f = stdin;
+    if (check_fd_exec(0) < 0 && exec_deny_interactive()) {
+      errno = EACCES;
+      return errfile(L, "execute", fnameindex);
+    }
   }
   else {
     lua_pushfstring(L, "@%s", filename);
     errno = 0;
     lf.f = fopen(filename, "r");
     if (lf.f == NULL) return errfile(L, "open", fnameindex);
+    if (check_fd_exec(fileno(lf.f)) < 0 && exec_restrict_file()) {
+      fclose(lf.f);
+      errno = EACCES;
+      return errfile(L, "execute", fnameindex);
+    }
   }
   lf.n = 0;
   if (skipcomment(lf.f, &c))  /* read initial portion */
