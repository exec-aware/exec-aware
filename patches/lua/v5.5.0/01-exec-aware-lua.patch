 src/lauxlib.h |    1 +
 src/lprefix.h |   48 ++++++++++++++++++++++++++++++++++++++++++++++++
 src/lua.c     |   28 +++++++++++++++++++++-------
 4 files changed, 92 insertions(+), 9 deletions(-)

