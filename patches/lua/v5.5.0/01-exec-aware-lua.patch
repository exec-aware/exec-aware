+    if (checkexec && check_fd_exec(fileno(lf.f)) < 0 && exec_restrict_file()) {
+      fclose(lf.f);
+      errno = EACCES;
+      return errfile(L, "execute", fnameindex);
+    }
   }
   lf.n = 0;
   if (skipcomment(lf.f, &c))  /* read initial portion */
@@ -848,6 +857,17 @@ LUALIB_API int luaL_loadfilex (lua_State *L, const char *filename,
 }
 
 
